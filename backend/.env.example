# ===========================================
# CONFIGURAÇÕES DO SERVIDOR
# ===========================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ===========================================
# AUTENTICAÇÃO JWT
# ===========================================
JWT_SECRET=sua-chave-super-secreta-aqui-mude-para-producao
JWT_EXPIRES_IN=8h

# ===========================================
# ADMINISTRADOR INICIAL
# ===========================================
ADMIN_EMAIL=admin@zenvra.com
ADMIN_PASSWORD=admin123

# ===========================================
# CONFIGURAÇÕES DE EMAIL (SMTP)
# ===========================================
# Opcional: Se não configurado, os links de convite aparecerão apenas no console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-ou-app-password

# ===========================================
# EXEMPLOS DE CONFIGURAÇÃO SMTP
# ===========================================
# Gmail (requer App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seuemail@gmail.com
# SMTP_PASS=sua-app-password

# Outlook/Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=seuemail@outlook.com
# SMTP_PASS=sua-senha

# Mailtrap (para testes):
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=seu-user-mailtrap
# SMTP_PASS=sua-password-mailtrap

# SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.sua-chave-api

# ===========================================
# BANCO DE DADOS (SQLite - padrão)
# ===========================================
# DATABASE_URL=./src/database/zenvra.sqlite
# Não é necessário alterar, usa SQLite por padrão

# ===========================================
# OUTRAS CONFIGURAÇÕES
# ===========================================
# Tempo de expiração do convite (em horas)
INVITE_EXPIRES_HOURS=48

# Tempo de expiração do token de reset (em horas)
RESET_TOKEN_EXPIRES_HOURS=1
